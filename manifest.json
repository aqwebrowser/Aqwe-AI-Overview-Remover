{
  "manifest_version": 3,
  "name": "AI Overview Remover",
  "version": "1.0.0",
  "description": "Removes Google AI Overview from search results.",
  "icons": {
    "128": "Logo.jpg"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/*"
      ],
      "css": [
        "hide.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}